# ==== Порт ====
PORT=3000

# ==== ВАШ (вендорский) AmoCRM — куда создаются сделки об установках ====
# Поддомен вашего аккаунта (https://ЭТО.amocrm.ru).
VENDOR_SUBDOMAIN=mycompany

# ПРОСТОЙ ПУТЬ (рекомендуется): долгоживущий токен из приватной интеграции.
# Если он задан — VENDOR_CLIENT_ID/SECRET/REDIRECT и /oauth/vendor НЕ нужны.
VENDOR_LONG_LIVED_TOKEN=

# Альтернатива (OAuth с авто-refresh) — заполнять, только если НЕ используете токен выше:
VENDOR_CLIENT_ID=00000000-0000-0000-0000-000000000000
VENDOR_CLIENT_SECRET=ВАШ_СЕКРЕТ_ПРИВАТНОЙ_ИНТЕГРАЦИИ
VENDOR_REDIRECT_URI=https://your-backend.example.com/oauth/vendor

# ==== ПУБЛИЧНАЯ интеграция (виджет в amoMarket) ====
# Из кабинета разработчика amoCRM. redirect_uri должен указывать на /oauth этого бэкенда.
PUBLIC_CLIENT_ID=00000000-0000-0000-0000-000000000000
PUBLIC_CLIENT_SECRET=ВАШ_СЕКРЕТ_ПУБЛИЧНОЙ_ИНТЕГРАЦИИ
PUBLIC_REDIRECT_URI=https://your-backend.example.com/oauth
